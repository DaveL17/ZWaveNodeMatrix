<?xml version="1.0"?>
<Template>

    <Field id="nodeMarker" type="menu" defaultValue="." tooltip="Select the marker style (note that some marker styles do not support all configuration options.)">
        <Label>Node Marker:</Label>
        <List>
            <Option value="o">Circle</Option>
            <Option value="D">Diamond</Option>
            <Option value="d">Diamond (Thin)</Option>
            <Option value="h">Hexagon 1</Option>
            <Option value="H">Hexagon 2</Option>
            <Option value="_">Horizontal Line</Option>
            <Option value="8">Octagon</Option>
            <Option value="p">Pentagon</Option>
            <Option value=",">Pixel</Option>
            <Option value="+">Plus</Option>
            <Option value="P">Plus (filled)</Option>
            <Option value=".">Point*</Option>
            <Option value="*">Star</Option>
            <Option value="s">Square</Option>
            <Option value="1">Triangle Down (unfilled)</Option>
            <Option value="3">Triangle Left (unfilled)</Option>
            <Option value="4">Triangle Right (unfilled)</Option>
            <Option value="2">Triangle Up (unfilled)</Option>
            <Option value="v">Triangle Down (filled)</Option>
            <Option value="&lt;">Triangle Left (filled)</Option>
            <Option value="&gt;">Triangle Right (filled)</Option>
            <Option value="^">Triangle Up (filled)</Option>
            <Option value="|">Vertical Line</Option>
            <Option value="x">X</Option>
            <Option value="X">X (filled)</Option>
        </List>
    </Field>

</Template>
