<?xml version="1.0"?>
<!--suppress PyStatementEffect -->
<MenuItems>

    <MenuItem id="aboutMatplotlib">
        <Name>About Matplotlib...</Name>
        <ConfigUI>
            <!-- Matplotlib citation per TOS. -->
            <Field id="aboutLabel" type="label">
                <Label>Matplotlib is an open-source Python library for creating high-quality 2D visualizations and plots. It provides a flexible interface for generating charts such as line graphs, bar charts, scatter plots, histograms, and more, with extensive customization options. Widely used in scientific computing, data analysis, and education, Matplotlib works seamlessly with libraries like NumPy and pandas and supports multiple output formats for publication-quality figures.</Label>
            </Field>
            <Field id="authorLabel" type="label">
                <Label>Authored by: J.D. Hunter</Label>
            </Field>
            <Field id="licenseLabel" type="label">
                <Label>https://matplotlib.org/stable/project/license.html</Label>
            </Field>
        </ConfigUI>
    </MenuItem>

    <MenuItem id="print_environment_info" uiPath="plugin_tools">
        <Name>Display Plugin Information</Name>
        <CallbackMethod>log_plugin_environment</CallbackMethod>
    </MenuItem>

    <MenuItem id="print_neighbor_list" uiPath="plugin_tools">
        <Name>Print Neighbor List</Name>
        <CallbackMethod>print_neighbor_list</CallbackMethod>
    </MenuItem>

    <MenuItem id="refreshMatrix">
        <Name>Refresh Matrix</Name>
        <CallbackMethod>make_the_matrix</CallbackMethod>
    </MenuItem>

</MenuItems>
